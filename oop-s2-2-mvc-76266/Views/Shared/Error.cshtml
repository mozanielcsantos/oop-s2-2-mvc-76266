@model OopS22Mvc76266.Web.Models.ErrorViewModel

@{
    ViewData["Title"] = "Error";
}

<div class="card panel-card p-5">
    <h1 class="page-title text-danger mb-3">Something went wrong</h1>

    <p class="page-subtitle mb-3">
        @Model.FriendlyMessage
    </p>

    @if (Model.ShowRequestId)
    {
        <p>
            <strong>Request ID:</strong> <code>@Model.RequestId</code>
        </p>
    }

    <p class="mb-4">
        Please go back to the previous page or return to the dashboard.
    </p>

    <div class="d-flex gap-2 flex-wrap">
        <a asp-controller="Home" asp-action="Index" class="btn btn-primary-soft">Go to Home</a>
        <a asp-controller="Dashboard" asp-action="Index" class="btn btn-outline-secondary">Go to Dashboard</a>
    </div>
</div>