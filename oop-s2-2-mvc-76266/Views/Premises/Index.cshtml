@model IEnumerable<FoodSafety.Domain.Entities.Premises>

@{
    ViewData["Title"] = "Premises";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="page-title mb-1">Premises</h1>
        <p class="page-subtitle mb-0">View and manage food business locations and their risk ratings.</p>
    </div>

    @if (User.IsInRole("Admin"))
    {
        <a asp-action="Create" class="btn btn-primary-soft">Add Premises</a>
    }
</div>

<div class="card panel-card p-3">
    <div class="table-responsive">
        <table class="table align-middle mb-0">
            <thead>
            <tr>
                <th>Name</th>
                <th>Address</th>
                <th>Town</th>
                <th>Risk Rating</th>
            </tr>
            </thead>
            <tbody>
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="4" class="empty-state text-center">No premises found.</td>
                </tr>
            }
            else
            {
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Name</td>
                        <td>@item.Address</td>
                        <td>@item.Town</td>
                        <td>@item.RiskRating</td>
                    </tr>
                }
            }
            </tbody>
        </table>
    </div>
</div>