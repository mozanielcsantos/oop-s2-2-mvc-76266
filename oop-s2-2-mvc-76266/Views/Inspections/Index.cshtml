@model IEnumerable<FoodSafety.Domain.Entities.Inspection>

@{
    ViewData["Title"] = "Inspections";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="page-title mb-1">Inspections</h1>
        <p class="page-subtitle mb-0">Record and review inspection results for each premises.</p>
    </div>

    @if (User.IsInRole("Admin") || User.IsInRole("Inspector"))
    {
        <a asp-action="Create" class="btn btn-primary-soft">Create Inspection</a>
    }
</div>

<div class="card panel-card p-3">
    <div class="table-responsive">
        <table class="table align-middle mb-0">
            <thead>
            <tr>
                <th>Date</th>
                <th>Premises</th>
                <th>Town</th>
                <th>Score</th>
                <th>Outcome</th>
                <th>Notes</th>
            </tr>
            </thead>
            <tbody>
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="6" class="empty-state text-center">No inspections found.</td>
                </tr>
            }
            else
            {
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.InspectionDate.ToString("yyyy-MM-dd")</td>
                        <td>@item.Premises?.Name</td>
                        <td>@item.Premises?.Town</td>
                        <td>@item.Score</td>
                        <td>
                            <span class="@(item.Outcome == "Fail" ? "status-fail" : "status-pass")">
                                @item.Outcome
                            </span>
                        </td>
                        <td>@item.Notes</td>
                    </tr>
                }
            }
            </tbody>
        </table>
    </div>
</div>