@model OopS22Mvc76266.Web.ViewModels.DashboardViewModel

@{
    ViewData["Title"] = "Dashboard";
}

<h1>Dashboard</h1>

<form method="get">
    <div style="display:flex; gap:20px; margin-bottom:20px;">
        <div>
            <label for="town">Town</label>
            <select id="town" name="town">
                <option value="">All</option>
                @foreach (var town in Model.AvailableTowns)
                {
                    if (Model.Town == town)
                    {
                        <option value="@town" selected>@town</option>
                    }
                    else
                    {
                        <option value="@town">@town</option>
                    }
                }
            </select>
        </div>

        <div>
            <label for="riskRating">Risk Rating</label>
            <select id="riskRating" name="riskRating">
                <option value="">All</option>
                @foreach (var rating in Model.AvailableRiskRatings)
                {
                    if (Model.RiskRating == rating)
                    {
                        <option value="@rating" selected>@rating</option>
                    }
                    else
                    {
                        <option value="@rating">@rating</option>
                    }
                }
            </select>
        </div>

        <div style="align-self:end;">
            <button type="submit">Apply Filters</button>
            <a href="/Dashboard">Reset</a>
        </div>
    </div>
</form>

<div style="display:grid; grid-template-columns: repeat(3, 1fr); gap:20px;">
    <div style="border:1px solid #ccc; padding:20px; border-radius:8px;">
        <h3>Inspections This Month</h3>
        <p style="font-size:28px; font-weight:bold;">@Model.InspectionsThisMonth</p>
    </div>

    <div style="border:1px solid #ccc; padding:20px; border-radius:8px;">
        <h3>Failed Inspections This Month</h3>
        <p style="font-size:28px; font-weight:bold; color:#b00020;">@Model.FailedInspectionsThisMonth</p>
    </div>

    <div style="border:1px solid #ccc; padding:20px; border-radius:8px;">
        <h3>Overdue Open Follow-Ups</h3>
        <p style="font-size:28px; font-weight:bold; color:#d97706;">@Model.OverdueOpenFollowUps</p>
    </div>
</div>